+
+	cfgJSON := `{
+		"api_key": "test-key",
+		"model_overrides": {
+			"claude-sonnet-4.5": {
+				"provider": "opencode-zen",
+				"model_id": "claude-sonnet-4.5",
+				"temperature": 0.5,
+				"max_tokens": 4096
+			}
+		}
+	}`
+
+	if err := os.WriteFile(cfgPath, []byte(cfgJSON), 0644); err != nil {
+		t.Fatalf("failed to write test config: %v", err)
+	}
+
