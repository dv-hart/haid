+		t.Errorf("ModelID = %q, want %q", entry.ModelID, "claude-sonnet-4.5")
+	}
+	if entry.Temperature != 0.5 {
+		t.Errorf("Temperature = %f, want 0.5", entry.Temperature)
+	}
