diff --git a/crates/cli/src/templates/js-astgrep/scripts/PROJECT.toml.ts b/crates/cli/src/templates/js-astgrep/scripts/PROJECT.toml.ts
new file mode 100644
index 000000000..dd7935847
--- /dev/null
+++ b/crates/cli/src/templates/js-astgrep/scripts/PROJECT.toml.ts
@@ -0,0 +1,33 @@
+import type { PROJECT, Edit } from "PROJECT:ast-grep";
+import type Toml from "PROJECT:ast-grep/langs/toml";
+
+const PROJECT: PROJECT<Toml> = async (root) => {
+  const rootNode = root.root();
+
+  const packageManagerPairs = rootNode.findAll({
+    rule: {
+      kind: "pair",
+      has: {
+        kind: "bare_key",
+        regex: "^package-manager$",
+      },
+    },
+  });
+
+  const edits = packageManagerPairs
+    .map((node) => {
+      if (node.text() === 'package-manager = "EMAIL"') {
+        return null;
+      }
+      return node.replace('package-manager = "EMAIL"');
+    })
+    .filter(Boolean);
+
+  if (edits.length === 0) {
+    return null;
+  }
+
+  return rootNode.commitEdits(edits as Edit[]);
+};
+
+export default PROJECT;
